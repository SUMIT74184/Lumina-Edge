# -----------------------------------------------------------------------------
# Lumina Edge - Deployment Environment Configuration
# -----------------------------------------------------------------------------
# This file serves as a template. Do NOT commit your actual .env to version control.
# Copy this file to `.env` and fill in your production values.

# -- Database Configuration --
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# -- Clerk Authentication Secrets --
# You can find these in your Clerk Dashboard under API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- Clerk Redirect URLs --
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# -- API URL --
# In production, this should be your backend's public URL.
# If deploying locally or using Docker networking directly from the client, use your local IP or localhost.
# Example: https://api.luminaedge.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
